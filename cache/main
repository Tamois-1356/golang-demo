package cache

import "fmt"

// Doubly Linked List Node

type node struct {
	key        string
	value      string
	prev, next *node
}

// LRUCache

// LRUCache là một bộ nhớ đệm có dung lượng cố định, sẽ loại bỏ mục được sử dụng ít nhất gần đây
// khi một khóa mới được chèn vượt quá dung lượng.
type LRUCache struct {
	capacity int
	items    map[string]*node
	head     *node
	tail     *node
}

// Tạo mới một LRUCache mới với dung lượng cho trước (phải > 0).
func New(capacity int) *LRUCache {
	if capacity <= 0 {
		panic("capacity must be > 0")
	}
	head := &node{}
	tail := &node{}
	head.next = tail
	tail.prev = head
	return &LRUCache{
		capacity: capacity,
		items:    make(map[string]*node, capacity),
		head:     head,
		tail:     tail,
	}
}

// Get trả về giá trị cho key và một cờ ok.
// Mục được truy cập sẽ được đưa lên vị trí MRU.
func (c *LRUCache) Get(key string) (string, bool) {
	n, ok := c.items[key]
	if !ok {
		return "", false
	}
	c.moveToFront(n)
	return n.value, true
}

// Thêm hoặc cập nhật cặp khóa-giá trị.
// Mục này sẽ trở thành mục được sử dụng gần nhất. Nếu bộ nhớ đệm đầy, mục ít sử dụng nhất sẽ bị loại bỏ.
func (c *LRUCache) Put(key, value string) {
	if n, ok := c.items[key]; ok {
		// Cập nhật node hiện có và nâng cấp nó
		n.value = value
		c.moveToFront(n)
		return
	}
	// Chèn nút mới ở đầu (MRU)
	n := &node{key: key, value: value}
	c.items[key] = n
	c.addToFront(n)

	// Đuổi phần ít dùng nhất nếu vượt quá dung lượng
	if len(c.items) > c.capacity {
		lru := c.removeTail()
		delete(c.items, lru.key)
	}
}

// Private helpers

// addToFront chèn n ngay sau đầu giả.
func (c *LRUCache) addToFront(n *node) {
	n.prev = c.head
	n.next = c.head.next
	c.head.next.prev = n
	c.head.next = n
}

// removeNode tách n ra khỏi danh sách mà không giải phóng nó.
func (c *LRUCache) removeNode(n *node) {
	n.prev.next = n.next
	n.next.prev = n.prev
}

// moveToFront di chuyển một nút hiện có đến vị trí MRU.
func (c *LRUCache) moveToFront(n *node) {
	c.removeNode(n)
	c.addToFront(n)
}

// removeTail xóa và trả về node LRU (node ngay trước đuôi giả).
func (c *LRUCache) removeTail() *node {
	lru := c.tail.prev
	c.removeNode(lru)
	return lru
}

// Test

func main() {
	cache := New(3)

	cache.Put("a", "1")
	cache.Put("b", "2")
	cache.Put("c", "3")

	if v, ok := cache.Get("a"); ok {
		fmt.Println("a:", v)
	}


	cache.Put("d", "4")

	if _, ok := cache.Get("b"); !ok {
		fmt.Println("b: evicted")
	}
	if v, ok := cache.Get("c"); ok {
		fmt.Println("c:", v)
	}
	if v, ok := cache.Get("d"); ok {
		fmt.Println("d:", v)
	}
}
